{
  "typeCheckingMode": "standard",
  "pythonVersion": "3.11",
  "reportMissingParameterType": "warning",
  "reportUnknownParameterType": "none",
  "include": ["src", "tests", "scripts/check_numpy_typing.py"],
  "reportMissingImports": "none",
  "reportMissingModuleSource": "none",
  "venvPath": ".",
  "exclude": [
    "**/__pycache__",
    ".venv",
    "build",
    "dist"
  ]
}
