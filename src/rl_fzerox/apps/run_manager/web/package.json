{
  "name": "rl-fzerox-run-manager",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "biome format --write src index.html vite.config.ts package.json tsconfig.json",
    "lint": "biome lint src index.html vite.config.ts",
    "biome-check": "biome check src index.html vite.config.ts package.json tsconfig.json",
    "check": "tsc -b && biome check src index.html vite.config.ts package.json tsconfig.json"
  },
  "dependencies": {
    "elkjs": "^0.11.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
